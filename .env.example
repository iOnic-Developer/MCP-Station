# ── Required ─────────────────────────────────────────────────────────────
# Password for the admin UI and the OAuth approval page.
APP_PASSWORD=change-me

# Public https base URL (no trailing slash). Enables the OAuth server so
# claude.ai can add each MCP as a custom connector, e.g. https://dbzocchi.app/gemini_mcp
PUBLIC_URL=https://dbzocchi.app

# ── Strongly recommended ─────────────────────────────────────────────────
# Fixed long random string: sessions + encrypted secrets survive restarts.
# If unset, a key is generated and persisted in /data/secret.key instead.
SESSION_SECRET=

# Static bearer token that also unlocks every MCP endpoint (for Claude Code
# CLI / scripts): Authorization: Bearer <MCP_TOKEN>. Unset = OAuth only.
MCP_TOKEN=

# ── Assistant (Claude popup) ─────────────────────────────────────────────
# Can also be set in the UI (stored encrypted). Env var wins if both set.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Tuning ───────────────────────────────────────────────────────────────
PORT=8788
# Set 1 when served over HTTPS (behind SWAG / Nginx Proxy Manager).
COOKIE_SECURE=1
# Where state, backups and the encryption key live (map to a volume).
DATA_DIR=/data
# Where MCP module folders live (map to a volume to keep custom modules).
MCPS_DIR=/app/mcps
